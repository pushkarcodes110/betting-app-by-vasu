# Django Settings
SECRET_KEY=your-secret-key-here-generate-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,35.200.208.215,your-domain.com

# Database Settings (Internal PostgreSQL in Docker)
POSTGRES_DB=bettingdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database URL (Alternative format)
DATABASE_URL=postgresql://postgres:your-strong-password-here@db:5432/bettingdb

# Runtime tuning
RUN_MIGRATIONS=true
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_KEEPALIVE=2
GUNICORN_MAX_REQUESTS=500
GUNICORN_MAX_REQUESTS_JITTER=50
GUNICORN_ACCESS_LOG=false
DB_CONN_MAX_AGE=60

# Optional: For production
DJANGO_SETTINGS_MODULE=mymainserver.settings
